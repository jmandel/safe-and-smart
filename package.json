{
  "name": "safe-and-smart",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser-only clinical applet sandbox: one trusted wrapper safely hosts many sandboxed SMART-on-FHIR applets. Bundled with Bun.",
  "scripts": {
    "build": "bun run build.ts",
    "build:pages": "VITE_SANDBOX_ORIGIN=self bun run build.ts",
    "start": "bun run build.ts && node tools/serve.mjs",
    "serve": "node tools/serve.mjs",
    "test": "bun test tests/*.test.ts",
    "test:redteam": "bun tests/security/redteam.mjs",
    "test:smoke": "bun tests/content/smoke.mjs",
    "gen:types": "bun tools/generate-schema-types.ts",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.tools.json --pretty false",
    "verify": "bun run typecheck && bun run test",
    "release": "VITE_SANDBOX_ORIGIN=self bun run build.ts && bun run tools/release-manifest.ts"
  },
  "dependencies": {
    "@quilted/threads": "4.0.3",
    "@remote-dom/core": "1.11.1",
    "@remote-dom/react": "1.2.2",
    "esbuild-wasm": "0.25.0",
    "fhirclient": "2.6.3",
    "postcss": "8.5.15",
    "prismjs": "1.29.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-simple-code-editor": "0.14.1",
    "vega-embed": "7.1.0",
    "vega-interpreter": "2.2.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/node": "24.3.0",
    "@types/react": "18.3.24",
    "@types/react-dom": "18.3.7",
    "@xmldom/xmldom": "0.8.13",
    "bun-types": "1.3.14",
    "playwright-core": "1.61.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.1",
    "node": ">=22"
  }
}
